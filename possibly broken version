# ======================================================================
#  Brain – V16: adds serotonin (5‑HT)
# ======================================================================
class Brain:
    def __init__(self):
        self.regions         = []
        self._all_neurons    = []
        self._all_synapses   = []
        self._projection_map = []
        self._thalamus       = None

        self.sleep_pressure   = 0.0
        self.sleep_threshold  = 1.0
        self.wake_threshold   = 0.2
        self.buildup_rate     = 0.00003
        self.passive_recovery = 0.00005
        self.state            = "wake"
        self.last_replay      = -1000

        self.dopamine         = 0.0
        self.dopamine_tau     = 200.0

        self.acetylcholine    = 1.0
        self.norepinephrine   = 1.0
        self.ach_tau          = 500.0
        self.ne_tau           = 200.0

        # Serotonin (V16)
        self.serotonin        = 0.5   # tonic level
        self.serotonin_tau    = 1000.0  # slow decay

    def add_region(self, region):
        self.regions.append(region)
        self._all_neurons.extend(region.neurons)
        self._all_synapses.extend(region.internal_synapses)
        if isinstance(region, Thalamus):
            self._thalamus = region
        return region

    def connect(self, pre_region, post_region,
                projection_type="feedforward", n_connections=4, target="input",
                dopamine_receptor=None):
        preset   = PROJECTION[projection_type]
        synapses = pre_region.project_to(
            post_region,
            n_connections = n_connections,
            weight_range  = preset["weight_range"],
            delay_range   = preset["delay_range"],
            learn_rate    = preset["learn_rate"],
            target        = target,
            dopamine_receptor = dopamine_receptor,
        )
        self._all_synapses.extend(synapses)
        self._projection_map.append((pre_region, post_region, projection_type, synapses))
        return synapses

    def present(self, I):
        if self._thalamus is not None:
            self._thalamus.receive_input(I * (1.0 + 0.2 * self.acetylcholine))
        else:
            raise RuntimeError("No Thalamus region added.")

    def step(self, t, dt=1.0):
        for syn in self._all_synapses:
            syn.deliver()
        for syn in self._all_synapses:
            syn.step(dt)

        if self.state == "sleep" and t - self.last_replay >= 200:
            for region in self.regions:
                if "Hippocampus" in region.name:
                    for n in region.input_neurons:
                        n.receive(0.25)
            self.last_replay = t

        self.dopamine *= np.exp(-dt / self.dopamine_tau)
        if t > 0 and t % 2000 == 0 and self.state == "wake":
            self.dopamine = 1.0

        target_ach = 1.0 if self.state == "wake" else 0.0
        target_ne  = 1.0 if self.state == "wake" else 0.0
        target_5ht = 0.5 if self.state == "wake" else 0.0   # serotonin drops during sleep
        self.acetylcholine  += dt * (target_ach - self.acetylcholine) / self.ach_tau
        self.norepinephrine += dt * (target_ne  - self.norepinephrine) / self.ne_tau
        self.serotonin      += dt * (target_5ht - self.serotonin) / self.serotonin_tau

        fired = set()
        for neuron in self._all_neurons:
            if neuron.step(t, dt, norepinephrine=self.norepinephrine, serotonin=self.serotonin):
                fired.add(neuron)

        for syn in self._all_synapses:
            syn.enqueue(syn.pre in fired)

        for syn in self._all_synapses:
            if syn.post in fired:
                syn.stdp_update(t, dopamine=self.dopamine,
                                acetylcholine=self.acetylcholine)

        if t > 0 and t % 50 == 0:
            for neuron in self._all_neurons:
                neuron.homeostatic_step(window_ms=50)

        recovery_rate = (0.005 if self.state == "sleep" else 0.0005)
        for neuron in self._all_neurons:
            neuron.fatigue = max(0.0, neuron.fatigue - recovery_rate * dt)

        total_spikes = len(fired)
        self.sleep_pressure += total_spikes * self.buildup_rate - self.passive_recovery * dt
        self.sleep_pressure = max(0.0, self.sleep_pressure)

        if self.state == "wake" and self.sleep_pressure > self.sleep_threshold:
            self.state = "sleep"
            print(f"  >>> t={t}: entering SLEEP state (pressure={self.sleep_pressure:.3f})")
        elif self.state == "sleep" and self.sleep_pressure < self.wake_threshold:
            self.state = "wake"
            print(f"  >>> t={t}: waking up (pressure={self.sleep_pressure:.3f})")

        return fired

    def stats(self):
        total = sum(n.firing_rate for n in self._all_neurons)
        print(f"\n{'═'*56}")
        print(f"  BRAIN  |  {len(self._all_neurons)} neurons  "
              f"{len(self._all_synapses)} synapses  "
              f"{len(self.regions)} regions  "
              f"{total} total spikes  "
              f"state={self.state}  pressure={self.sleep_pressure:.3f}"
              f"  DA={self.dopamine:.3f} ACh={self.acetylcholine:.3f} NE={self.norepinephrine:.3f} 5HT={self.serotonin:.3f}")
        print(f"{'═'*56}")
        for region in self.regions:
            region.stats()
        print(f"\n  Inter-region projections:")
        for pre, post, ptype, syns in self._projection_map:
            avg_w = np.mean([s.weight for s in syns])
            print(f"    {pre.name:14s} → {post.name:14s}  "
                  f"[{ptype:11s}]  {len(syns)} axons  avg_w={avg_w:.3f}")
        print(f"{'═'*56}\n")


# -------------------------
# Fast (Numba-capable) core
# -------------------------
def _prepare_numba_arrays(brain):
    neurons = list(brain._all_neurons)
    N = len(neurons)
    idx = {n: i for i, n in enumerate(neurons)}

    v = np.zeros(N, dtype=np.float64)
    v_reset = np.zeros(N, dtype=np.float64)
    base_threshold = np.zeros(N, dtype=np.float64)
    tau_m = np.zeros(N, dtype=np.float64)
    pending_I = np.zeros(N, dtype=np.float64)
    g_ampa = np.zeros(N, dtype=np.float64)
    g_gaba = np.zeros(N, dtype=np.float64)
    g_ahp = np.zeros(N, dtype=np.float64)
    tau_ampa = np.zeros(N, dtype=np.float64)
    tau_gaba = np.zeros(N, dtype=np.float64)
    eta = np.zeros(N, dtype=np.float64)
    tau_noise = np.zeros(N, dtype=np.float64)
    noise_std = np.zeros(N, dtype=np.float64)
    last_spike = np.full(N, -1000.0, dtype=np.float64)
    refractory = np.zeros(N, dtype=np.float64)
    has_t_current = np.zeros(N, dtype=np.int32)
    I_burst = np.zeros(N, dtype=np.float64)
    adapt_gain = np.zeros(N, dtype=np.float64)
    adapt_tau = np.zeros(N, dtype=np.float64)
    fatigue = np.zeros(N, dtype=np.float64)
    _scale = np.ones(N, dtype=np.float64)
    d2_mask = np.zeros(N, dtype=np.int32)
    biophysical = np.zeros(N, dtype=np.int32)
    Cm = np.ones(N, dtype=np.float64)
    g_leak = np.ones(N, dtype=np.float64)
    E_leak = np.zeros(N, dtype=np.float64)
    E_exc = np.zeros(N, dtype=np.float64)
    E_inh = np.zeros(N, dtype=np.float64)
    E_ahp = np.zeros(N, dtype=np.float64)

    for i, n in enumerate(neurons):
        v[i] = n.v
        v_reset[i] = n.v_reset
        base_threshold[i] = n.base_threshold
        tau_m[i] = n.tau_m
        pending_I[i] = n._pending_I
        g_ampa[i] = n.g_ampa
        g_gaba[i] = n.g_gaba
        g_ahp[i] = n.g_ahp
        eta[i] = n.eta
        tau_noise[i] = getattr(n, 'tau_noise', 5.0)
        noise_std[i] = n.noise_std
        last_spike[i] = n.last_spike_time
        refractory[i] = n.refractory
        has_t_current[i] = 1 if n.has_t_current else 0
        I_burst[i] = getattr(n, 'I_burst', 0.0)
        adapt_gain[i] = n.adapt_gain
        adapt_tau[i] = n.adapt_tau
        tau_ampa[i] = n.tau_ampa
        tau_gaba[i] = n.tau_gaba
        fatigue[i] = n.fatigue
        _scale[i] = n._scale
        d2_mask[i] = 1 if getattr(n, 'cell_type', '') == 'D2_MSN' else 0
        if getattr(n, 'biophysical', False):
            biophysical[i] = 1
            Cm[i] = getattr(n, 'Cm', 200.0)
            g_leak[i] = getattr(n, 'g_leak', Cm[i] / n.tau_m)
            E_leak[i] = getattr(n, 'E_leak', n.v_reset)
            E_exc[i] = getattr(n, 'E_exc', 0.0)
            E_inh[i] = getattr(n, 'E_inh', -75.0)
            E_ahp[i] = getattr(n, 'E_ahp', -90.0)
        else:
            biophysical[i] = 0
            E_exc[i] = n.E_exc
            E_inh[i] = n.E_inh
            E_ahp[i] = getattr(n, 'E_ahp', -90.0)

    # build outgoing synapse map
    syns = list(brain._all_synapses)
    S = len(syns)
    pre_idx = np.zeros(S, dtype=np.int32)
    post_idx = np.zeros(S, dtype=np.int32)
    for j, s in enumerate(syns):
        pre_idx[j] = idx[s.pre]
        post_idx[j] = idx[s.post]

    outgoing = [[] for _ in range(N)]
    for j in range(S):
        outgoing[int(pre_idx[j])].append(syns[j])

    arrays = dict(
        v=v, v_reset=v_reset, base_threshold=base_threshold,
        tau_m=tau_m, pending_I=pending_I, g_ampa=g_ampa, g_gaba=g_gaba,
        g_ahp=g_ahp, eta=eta, tau_noise=tau_noise, noise_std=noise_std,
        last_spike=last_spike, refractory=refractory, has_t_current=has_t_current,
        I_burst=I_burst, adapt_gain=adapt_gain, adapt_tau=adapt_tau,
        fatigue=fatigue, _scale=_scale, d2_mask=d2_mask,
        biophysical=biophysical, Cm=Cm, g_leak=g_leak, E_leak=E_leak,
        E_exc=E_exc, E_inh=E_inh, E_ahp=E_ahp,
        pre_idx=pre_idx, post_idx=post_idx,
    )
    arrays['tau_ampa'] = tau_ampa
    arrays['tau_gaba'] = tau_gaba
    return neurons, syns, arrays, outgoing


def _prepare_synapse_arrays(brain, neurons):
    """Convert brain._all_synapses into vectorized arrays and a ring buffer.
    Returns (syns, syn_arrays, buffer) where syns is the original list of
    Synapse objects (order matches arrays), syn_arrays is a dict of per-synapse
    arrays, and buffer is an array of shape (max_delay, S) for scheduled g_inc.
    """
    syns = list(brain._all_synapses)
    S = len(syns)
    idx = {n: i for i, n in enumerate(neurons)}

    if S == 0:
        syn_arrays = dict(pre_idx=np.zeros(0, dtype=np.int32),
                          post_idx=np.zeros(0, dtype=np.int32),
                          weight=np.zeros(0, dtype=np.float64),
                          syn_type=np.zeros(0, dtype=np.int8),
                          delay=np.zeros(0, dtype=np.int32),
                          use_stp=np.zeros(0, dtype=np.int8),
                          U=np.zeros(0, dtype=np.float64),
                          tau_facil=np.zeros(0, dtype=np.float64),
                          tau_rec=np.zeros(0, dtype=np.float64),
                          u=np.zeros(0, dtype=np.float64),
                          R=np.zeros(0, dtype=np.float64),
                          learn_rate=np.zeros(0, dtype=np.float64),
                          tau_ltp=np.zeros(0, dtype=np.float64),
                          tau_ltd=np.zeros(0, dtype=np.float64),
                          ltd_factor=np.zeros(0, dtype=np.float64),
                          dopamine_receptor=np.zeros(0, dtype=np.int8),
                          S=0, max_delay=1)
        buffer = np.zeros((1, 0), dtype=np.float64)
        return syns, syn_arrays, buffer

    pre_idx = np.zeros(S, dtype=np.int32)
    post_idx = np.zeros(S, dtype=np.int32)
    weight = np.zeros(S, dtype=np.float64)
    syn_type = np.zeros(S, dtype=np.int8)
    delay = np.zeros(S, dtype=np.int32)
    use_stp = np.zeros(S, dtype=np.int8)
    U = np.zeros(S, dtype=np.float64)
    tau_facil = np.zeros(S, dtype=np.float64)
    tau_rec = np.zeros(S, dtype=np.float64)
    u = np.zeros(S, dtype=np.float64)
    R = np.ones(S, dtype=np.float64)

    for j, s in enumerate(syns):
        pre_idx[j] = idx.get(s.pre, -1)
        post_idx[j] = idx.get(s.post, -1)
        weight[j] = float(getattr(s, 'weight', 0.0))
        syn_type[j] = 1 if getattr(s, 'synapse_type', 'excitatory') == 'excitatory' else -1
        delay[j] = int(getattr(s, 'delay', 1))
        use_stp[j] = 1 if getattr(s, 'use_stp', False) else 0
        U[j] = float(getattr(s, 'U', 0.5))
        tau_facil[j] = float(getattr(s, 'tau_facil', 50.0))
        tau_rec[j] = float(getattr(s, 'tau_rec', 200.0))
        u[j] = float(getattr(s, 'u', U[j]))
        R[j] = float(getattr(s, 'R', 1.0))
        # STDP / learning parameters
        learn_rate_arr = float(getattr(s, 'learn_rate', 0.01))
        tau_ltp_arr = float(getattr(s, 'tau_ltp', 17.0))
        tau_ltd_arr = float(getattr(s, 'tau_ltd', 34.0))
        ltd_factor_arr = float(getattr(s, 'ltd_factor', 0.65))
        dr = getattr(s, 'dopamine_receptor', None)
        if dr == 'D1':
            dr_code = 1
        elif dr == 'D2':
            dr_code = 2
        else:
            dr_code = 0
        # store into per-syn arrays
        # lazy initialization for these arrays (create above the loop)
        try:
            learn_rate[j] = learn_rate_arr
            tau_ltp[j] = tau_ltp_arr
            tau_ltd[j] = tau_ltd_arr
            ltd_factor[j] = ltd_factor_arr
            dopamine_receptor[j] = dr_code
        except Exception:
            # first-time creation: do nothing here (we populate after loop)
            pass

    max_delay = int(max(1, int(np.max(delay))))
    buffer = np.zeros((max_delay, S), dtype=np.float64)

    # Convert Synapse._buffer deques into buffer rows: leftmost (popleft) -> buffer[0]
    for j, s in enumerate(syns):
        try:
            dlist = list(s._buffer)
        except Exception:
            dlist = []
        for k, item in enumerate(dlist):
            if k >= max_delay:
                break
            g_inc, stype = item
            if g_inc != 0.0 and stype is not None:
                buffer[k, j] = float(g_inc)

    # create learning/STDP arrays (fill with defaults then overwrite where available)
    learn_rate = np.zeros(S, dtype=np.float64)
    tau_ltp = np.zeros(S, dtype=np.float64)
    tau_ltd = np.zeros(S, dtype=np.float64)
    ltd_factor = np.zeros(S, dtype=np.float64)
    dopamine_receptor = np.zeros(S, dtype=np.int8)

    for j, s in enumerate(syns):
        learn_rate[j] = float(getattr(s, 'learn_rate', 0.01))
        tau_ltp[j] = float(getattr(s, 'tau_ltp', 17.0))
        tau_ltd[j] = float(getattr(s, 'tau_ltd', 34.0))
        ltd_factor[j] = float(getattr(s, 'ltd_factor', 0.65))
        dr = getattr(s, 'dopamine_receptor', None)
        if dr == 'D1':
            dopamine_receptor[j] = 1
        elif dr == 'D2':
            dopamine_receptor[j] = 2
        else:
            dopamine_receptor[j] = 0

    syn_arrays = dict(pre_idx=pre_idx, post_idx=post_idx, weight=weight,
                      syn_type=syn_type, delay=delay, use_stp=use_stp,
                      U=U, tau_facil=tau_facil, tau_rec=tau_rec,
                      u=u, R=R,
                      learn_rate=learn_rate, tau_ltp=tau_ltp, tau_ltd=tau_ltd,
                      ltd_factor=ltd_factor, dopamine_receptor=dopamine_receptor,
                      S=S, max_delay=max_delay)
    return syns, syn_arrays, buffer


