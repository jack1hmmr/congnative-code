                    tau_ampa, tau_gaba,
                    dt, norepinephrine, serotonin, noise_sample, t):
        N = v.shape[0]
        fired = np.zeros(N, dtype=np.int32)
        for i in range(N):
            # OU noise
            eta[i] += dt * (-eta[i] / tau_noise[i]) + math.sqrt(max(1e-12, 2 * dt / tau_noise[i])) * noise_std[i] * noise_sample[i]
            # decay synaptic/adaptation conductances
            g_ahp[i] += dt * (-g_ahp[i] / adapt_tau[i])
