def scale_and_benchmark(scales=(1, 5, 10, 20), fanout=8, steps=200, biophysical=False, outgoing_fanout=2):
    results = []
    for scale in scales:
        t0 = time.perf_counter()
        brain = build_scaled_brain(scale=scale, fanout=fanout, biophysical=biophysical, outgoing_fanout=outgoing_fanout)
        build_time = time.perf_counter() - t0
        # run quick connectivity validation to ensure internal synapses are registered
        try:
            validate_connectivity(brain)
        except Exception as _e:
            print("validate_connectivity failed:", _e)

        # attempt to remove accidental duplicates before benchmarking
        try:
            removed = dedupe_synapses(brain, verbose=False)
            if removed > 0:
                print(f"  NOTE: deduped {removed} synapses before benchmarking")
        except Exception as _e:
            print("dedupe_synapses failed:", _e)

        N = len(brain._all_neurons)
        S = len(brain._all_synapses)
        print(f"Scale={scale}: built brain with {N} neurons, {S} synapses (build {build_time:.2f}s)")

        t1 = time.perf_counter()
        # use the fast path to step the network
        run_fast_simulation(brain, STEPS=steps, dt=1.0, record_history=False)
        run_time = time.perf_counter() - t1
        print(f"  Simulation: {steps} steps -> {run_time:.2f}s ({run_time/steps*1000:.2f} ms/step)")
        results.append((scale, N, S, build_time, run_time))
    return results

