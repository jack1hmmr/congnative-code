def run_fast_simulation(brain, STEPS=1000, dt=1.0, record_history=False):
    neurons, syn_objs, arrays, outgoing = _prepare_numba_arrays(brain)
    N = len(neurons)

    v = arrays['v']; v_reset = arrays['v_reset']; base_threshold = arrays['base_threshold']
    tau_m = arrays['tau_m']; pending_I = arrays['pending_I']; g_ampa = arrays['g_ampa']; g_gaba = arrays['g_gaba']
    g_ahp = arrays['g_ahp']; eta = arrays['eta']; tau_noise = arrays['tau_noise']; noise_std = arrays['noise_std']
    last_spike = arrays['last_spike']; refractory = arrays['refractory']; has_t_current = arrays['has_t_current']
    I_burst = arrays['I_burst']; adapt_gain = arrays['adapt_gain']; adapt_tau = arrays['adapt_tau']

    fatigue = arrays['fatigue']; _scale = arrays['_scale']; d2_mask = arrays['d2_mask']
    biophysical = arrays['biophysical']; Cm = arrays['Cm']; g_leak = arrays['g_leak']; E_leak = arrays['E_leak']
    E_exc = arrays['E_exc']; E_inh = arrays['E_inh']; E_ahp = arrays['E_ahp']

    # prepare synapse arrays + ring buffer
    syns, syn_arrays, syn_buffer = _prepare_synapse_arrays(brain, neurons)
    S = syn_arrays['S'] if syn_arrays is not None else 0
    pre_idx = syn_arrays['pre_idx'] if S > 0 else np.zeros(0, dtype=np.int32)
    post_idx = syn_arrays['post_idx'] if S > 0 else np.zeros(0, dtype=np.int32)
    weight = syn_arrays['weight'] if S > 0 else np.zeros(0, dtype=np.float64)
    syn_type = syn_arrays['syn_type'] if S > 0 else np.zeros(0, dtype=np.int8)
    delay = syn_arrays['delay'] if S > 0 else np.zeros(0, dtype=np.int32)
    use_stp = syn_arrays['use_stp'] if S > 0 else np.zeros(0, dtype=np.int8)
    U = syn_arrays['U'] if S > 0 else np.zeros(0, dtype=np.float64)
    tau_facil = syn_arrays['tau_facil'] if S > 0 else np.zeros(0, dtype=np.float64)
    tau_rec = syn_arrays['tau_rec'] if S > 0 else np.zeros(0, dtype=np.float64)
    u = syn_arrays['u'] if S > 0 else np.zeros(0, dtype=np.float64)
    R = syn_arrays['R'] if S > 0 else np.ones(0, dtype=np.float64)
    max_delay = syn_arrays['max_delay'] if S > 0 else 1
    learn_rate = syn_arrays['learn_rate'] if S > 0 else np.zeros(0, dtype=np.float64)
    tau_ltp = syn_arrays['tau_ltp'] if S > 0 else np.zeros(0, dtype=np.float64)
    tau_ltd = syn_arrays['tau_ltd'] if S > 0 else np.zeros(0, dtype=np.float64)
    ltd_factor = syn_arrays['ltd_factor'] if S > 0 else np.zeros(0, dtype=np.float64)
    dopamine_receptor = syn_arrays['dopamine_receptor'] if S > 0 else np.zeros(0, dtype=np.int8)

    spike_map = {n: [] for n in neurons} if record_history else None

    current_bin = 0
    buffer_flat = syn_buffer.reshape(-1) if S > 0 else None

    for tstep in range(STEPS):
        # collect pending external currents from neuron objects into array
        for i, n in enumerate(neurons):
            pending_I[i] += n._pending_I
            n._pending_I = 0.0

        # deliver synaptic events from ring buffer into conductances
        if S > 0:
            g_row = syn_buffer[current_bin, :]
            if g_row.any():
                exc_mask = syn_type == 1
                inh_mask = syn_type == -1
                if exc_mask.any():
                    idxs = post_idx[exc_mask]
                    vals = g_row[exc_mask]
                    if vals.size:
                        np.add.at(g_ampa, idxs, vals)
                if inh_mask.any():
                    idxs = post_idx[inh_mask]
                    vals = g_row[inh_mask]
                    if vals.size:
                        np.add.at(g_gaba, idxs, vals)
            # clear delivered bin
            syn_buffer[current_bin, :] = 0.0

        # synapse STP recovery (vectorized)
        if S > 0 and use_stp.any():
            stp_mask = use_stp == 1
            R[stp_mask] += dt * ((1.0 - R[stp_mask]) / tau_rec[stp_mask])
            u[stp_mask] += dt * (-(u[stp_mask] - U[stp_mask]) / tau_facil[stp_mask])
            # clamps
            np.clip(R, 0.0, 1.0, out=R)
            np.clip(u, 0.0, 1.0, out=u)

        # noise samples
        noise_sample = np.random.normal(size=N)

        # neuron update (numba-accelerated if available)
        fired = _numba_step(v, v_reset, base_threshold, tau_m, pending_I, g_ampa, g_gaba, g_ahp,
                    eta, tau_noise, noise_std, last_spike, refractory, has_t_current,
                    I_burst, adapt_gain, adapt_tau, fatigue, _scale, d2_mask,
                    biophysical, Cm, g_leak, E_leak, E_exc, E_inh, E_ahp,
                    arrays['tau_ampa'], arrays['tau_gaba'],
                    dt, brain.norepinephrine, brain.serotonin, noise_sample, float(tstep))

        # record spikes and update neuron objects counters
        fired_idx = np.nonzero(fired)[0]
        for i in fired_idx:
            neurons[i].spike_times.append(tstep)
            neurons[i].last_spike_time = tstep
            neurons[i]._spike_counter += 1

        # enqueue synapses according to fired presynaptic neurons (vectorized into ring buffer)
        if S > 0 and fired_idx.size > 0:
            fired_bool = np.zeros(N, dtype=bool)
            fired_bool[fired_idx] = True
            pre_fired_mask = fired_bool[pre_idx]
            if pre_fired_mask.any():
                pf_idx = np.nonzero(pre_fired_mask)[0]
                # prepare g_inc values
                g_inc = np.zeros(pf_idx.size, dtype=np.float64)
                pf_syn_type = syn_type[pf_idx]
                pf_use_stp = use_stp[pf_idx] == 1

                # excitatory with STP
                mask_exc_stp = (pf_syn_type == 1) & pf_use_stp
                if mask_exc_stp.any():
                    sel = pf_idx[mask_exc_stp]
                    u[sel] = u[sel] + U[sel] * (1.0 - u[sel])
                    release = u[sel] * R[sel]
                    R[sel] = np.maximum(0.0, R[sel] - release)
                    g_inc[mask_exc_stp] = weight[sel] * release

                # excitatory without STP
                mask_exc_nostp = (pf_syn_type == 1) & (~pf_use_stp)
                if mask_exc_nostp.any():
                    sel = pf_idx[mask_exc_nostp]
                    g_inc[mask_exc_nostp] = weight[sel]

                # inhibitory (no STP semantics generally)
                mask_inh = (pf_syn_type == -1)
                if mask_inh.any():
                    sel = pf_idx[mask_inh]
                    g_inc[mask_inh] = weight[sel]

                # schedule into ring buffer
                target_bins = (current_bin + delay[pf_idx]) % max_delay
                # compute flat indices and add
                flat_idx = target_bins.astype(np.int64) * S + pf_idx.astype(np.int64)
                np.add.at(buffer_flat, flat_idx, g_inc)

                # write back updated u/R to syn objects for bookkeeping
                for local_j, global_j in enumerate(pf_idx):
                    try:
                        syns[global_j].u = float(u[global_j])
                        syns[global_j].R = float(R[global_j])
                    except Exception:
                        pass

        # STDP on posts that fired (call object method, then sync weight back into arrays)
        # Vectorized STDP: update weights for synapses whose post neuron fired
        if S > 0:
            post_fired_mask = fired[post_idx]
            if post_fired_mask.any():
                j_idx = np.nonzero(post_fired_mask)[0]
                pre_idx_j = pre_idx[j_idx]
                # delta_t = t_post - t_pre
                delta_t = (float(tstep) - last_spike[pre_idx_j])
                # learning parameters
                lr = learn_rate[j_idx]
                tau_ltp_j = tau_ltp[j_idx]
                tau_ltd_j = tau_ltd[j_idx]
                ltd_j = ltd_factor[j_idx]
                # compute dw
                dw = np.empty_like(delta_t, dtype=np.float64)
                pos_mask = delta_t > 0
                if pos_mask.any():
                    dw[pos_mask] = lr[pos_mask] * np.exp(-delta_t[pos_mask] / tau_ltp_j[pos_mask])
                neg_mask = ~pos_mask
                if neg_mask.any():
                    dw[neg_mask] = -lr[neg_mask] * ltd_j[neg_mask] * np.exp(delta_t[neg_mask] / tau_ltd_j[neg_mask])
                # modulators
                dw *= (1.0 + brain.acetylcholine)
                dr = dopamine_receptor[j_idx]
                da = brain.dopamine
                if da != 0.0:
                    # D1
                    d1_mask = (dr == 1)
                    if d1_mask.any():
                        pos = dw > 0
                        mask = d1_mask & pos
                        dw[mask] *= (1.0 + da)
                        mask = d1_mask & (~pos)
                        dw[mask] *= (1.0 - 0.5 * da)
                    # D2
                    d2_mask = (dr == 2)
                    if d2_mask.any():
                        pos = dw > 0
                        mask = d2_mask & pos
                        dw[mask] *= (1.0 - da)
                        mask = d2_mask & (~pos)
                        dw[mask] *= (1.0 + da)
                # apply updates and clip
                weight[j_idx] += dw
                np.clip(weight, 0.0, 2.0, out=weight)
                # sync back to syn objects
                for local_j, global_j in enumerate(j_idx):
                    try:
                        syns[global_j].weight = float(weight[global_j])
                    except Exception:
                        pass

        # periodic homeostasis / fatigue recovery
        if tstep > 0 and tstep % 50 == 0:
            for neuron in neurons:
                neuron.homeostatic_step(window_ms=50)

        recovery_rate = (0.005 if brain.state == "sleep" else 0.0005)
        for neuron in neurons:
            neuron.fatigue = max(0.0, neuron.fatigue - recovery_rate * dt)

        total_spikes = int(np.sum(fired))
        brain.sleep_pressure += total_spikes * brain.buildup_rate - brain.passive_recovery * dt
        brain.sleep_pressure = max(0.0, brain.sleep_pressure)

        if brain.state == "wake" and brain.sleep_pressure > brain.sleep_threshold:
            brain.state = "sleep"
            print(f"  >>> t={tstep}: entering SLEEP state (pressure={brain.sleep_pressure:.3f})")
        elif brain.state == "sleep" and brain.sleep_pressure < brain.wake_threshold:
            brain.state = "wake"
            print(f"  >>> t={tstep}: waking up (pressure={brain.sleep_pressure:.3f})")

        # advance ring buffer pointer
        current_bin = (current_bin + 1) % max_delay

    # write back voltages to neuron objects and conductances
    for i, n in enumerate(neurons):
        n.v = float(v[i])
        n.g_ampa = float(g_ampa[i])
        n.g_gaba = float(g_gaba[i])
        n.g_ahp = float(g_ahp[i])

    return neurons, syns


def test_single_neuron_fI(biophysical=False, durations=1000, dt=1.0):
    """Simple f-I curve test for a single neuron."""
    currents = np.linspace(0.0, 2.0, 6)
    results = []
    for I in currents:
        n = BrainNeuron(biophysical=biophysical, noise_std=0.0)
        spikes = 0
        for t in range(durations):
            n.receive(I)
            if n.step(t, dt):
                spikes += 1
        rate = spikes / (durations * dt * 0.001)  # spikes / second
        results.append((I, rate))
    print("f-I test (biophysical=%s):" % biophysical)
    for I, r in results:
        print(f"  I={I:.3f}  -> {r:.2f} Hz")
    return results


def test_psp_amplitude(biophysical=False, weight=0.5, dt=1.0):
    """Test PSP amplitude from a single presynaptic spike."""
    pre = BrainNeuron(biophysical=biophysical, noise_std=0.0)
    post = BrainNeuron(biophysical=biophysical, noise_std=0.0)
    syn = Synapse(pre, post, weight=weight, synapse_type='excitatory', delay=1, use_stp=False)
    # enqueue a single presynaptic spike
    syn.enqueue(True)
    # deliver immediately from buffer (simulate one step of delay)
    g_inc, syn_type = syn._buffer.popleft()
    if g_inc != 0.0 and syn_type is not None:
        if syn_type == 'excitatory':
            post.g_ampa += g_inc
        else:
            post.g_gaba += g_inc
    # run a few steps and record voltage
    vtrace = []
    for t in range(50):
        post.step(t, dt)
        vtrace.append(post.v)
    peak = max(vtrace)
    print(f"PSP peak (biophysical={biophysical}, weight={weight}): {peak}")
    return vtrace


def run_parity_tests(seeds=(42, 43, 44), durations=100, biophysical=False):
    """Run deterministic parity tests comparing object-path vs array-path.
    Returns list of failures (empty if OK).
    """
    failures = []
    for seed in seeds:
        np.random.seed(seed)
        brain = build_scaled_brain(scale=1, fanout=3, biophysical=biophysical, outgoing_fanout=1)
        # zero noise for determinism
        for n in brain._all_neurons:
            n.noise_std = 0.0
            n.eta = 0.0
            n._pending_I = 0.0

        # snapshot
        neuron_snap = []
        for n in brain._all_neurons:
            neuron_snap.append(dict(v=n.v, v_reset=n.v_reset, g_ampa=n.g_ampa, g_gaba=n.g_gaba,
                                    g_ahp=n.g_ahp, _pending_I=n._pending_I, last_spike_time=n.last_spike_time,
                                    spike_times=list(n.spike_times), _spike_counter=n._spike_counter,
                                    fatigue=n.fatigue, _scale=n._scale))
        syn_snap = []
        for s in brain._all_synapses:
            syn_snap.append(dict(weight=s.weight, u=s.u, R=s.R, buffer=list(s._buffer), delay=s.delay))

        # run object simulation
        for t in range(durations):
            brain.step(t, dt=1.0)
        obj_vs = [n.v for n in brain._all_neurons]
        obj_spike_counts = [len(n.spike_times) for n in brain._all_neurons]

        # restore
        for n, snap in zip(brain._all_neurons, neuron_snap):
            n.v = snap['v']; n.v_reset = snap['v_reset']; n.g_ampa = snap['g_ampa']; n.g_gaba = snap['g_gaba'];
            n.g_ahp = snap['g_ahp']; n._pending_I = snap['_pending_I']; n.last_spike_time = snap['last_spike_time'];
            n.spike_times = list(snap['spike_times']); n._spike_counter = snap['_spike_counter']; n.fatigue = snap['fatigue'];
            n._scale = snap['_scale']
        for s, snap in zip(brain._all_synapses, syn_snap):
            s.weight = snap['weight']; s.u = snap['u']; s.R = snap['R']; s._buffer = deque(snap['buffer'], maxlen=snap['delay'])

        # run fast simulation
        neurons2, syns2 = run_fast_simulation(brain, STEPS=durations, dt=1.0, record_history=False)
        fast_vs = [n.v for n in neurons2]
        fast_spike_counts = [len(n.spike_times) for n in neurons2]

        # compare
        diffs = []
        for i, (ov, fv, osc, fsc) in enumerate(zip(obj_vs, fast_vs, obj_spike_counts, fast_spike_counts)):
            if abs(ov - fv) > 1e-9 or osc != fsc:
                diffs.append((i, ov, fv, osc, fsc))
        if diffs:
            failures.append(dict(seed=seed, diffs=diffs[:20]))
    return failures


