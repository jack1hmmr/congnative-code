# Global neuron ID counter
_next_id = 0
def _uid():
    global _next_id
    _next_id += 1
    return _next_id - 1

# ======================================================================
#  PROJECTION TYPE PRESETS
# ======================================================================
PROJECTION = {
    "feedforward": dict(
        weight_range = (0.50, 0.65),
        delay_range  = (5,  10),
        learn_rate   = 0.001,
    ),
    "feedback": dict(
        weight_range = (0.15, 0.35),
        delay_range  = (10, 18),
        learn_rate   = 0.001,
    ),
    "modulatory": dict(
        weight_range = (0.05, 0.20),
        delay_range  = (15, 25),
        learn_rate   = 0.0005,
    ),
}

def gamma_delay(delay_range):
    min_d, max_d = delay_range
    raw = np.random.gamma(2.0, 1.5)
    delay = int(round(min_d + raw))
    delay = max(min_d, min(delay, max_d))
    return delay

# ======================================================================
#  BrainNeuron – V16: serotonin gain for D2 MSNs
# ======================================================================
class BrainNeuron:
    def __init__(self, tau_m=20.0, threshold=0.55, v_reset=0.0,
                 refractory=5, noise_std=0.008, target_rate=15.0,
                 adapt_gain=0.005, adapt_tau=200.0, layer=0,
                 cell_type="excitatory", has_t_current=False, biophysical=False):
        self.id              = _uid()
        self.tau_m           = tau_m
        self.base_threshold  = threshold
        self.v_reset         = v_reset
        self.v               = v_reset
        self.refractory      = refractory
        self.last_spike_time = -1000
        self.noise_std       = noise_std
        self.tau_noise       = 5.0
        self.eta             = 0.0
        self.spike_times     = []
        self.v_history       = []
        self.record_history  = True
        self._pending_I      = 0.0
        self.layer           = layer
        self.cell_type       = cell_type
        self.has_t_current   = has_t_current
        self.biophysical     = biophysical

        self.g_ahp           = 0.0
        self.adapt_gain      = adapt_gain
        self.adapt_tau       = adapt_tau

        self.target_rate     = target_rate
        self._scale          = np.random.uniform(0.85, 1.15)
        self._homeo_eta      = 0.05
        self._spike_counter  = 0
        self._rate_estimate  = target_rate

        self.fatigue         = 0.0
        self.max_fatigue     = 0.3
        self.spike_cost      = 0.035
        self.fatigue_recovery_wake = 0.0005
        self.fatigue_recovery_sleep = 0.005

        self.g_ampa = 0.0
        self.g_gaba = 0.0
        self.tau_ampa = 5.0
        self.tau_gaba = 10.0
        self.E_exc = 0.85
        self.E_inh = -0.15

        # Optional: switch to explicit biophysical units (mV, pF, nS, pA)
        if self.biophysical:
            # if user left the normalized defaults, replace with typical biophysical values
            if threshold == 0.55:
                self.base_threshold = -50.0  # mV
            if v_reset == 0.0:
                self.v_reset = -65.0  # mV
            self.v = self.v_reset
            self.Cm = 200.0   # pF
            self.E_leak = self.v_reset
            # membrane leak conductance (nS) approximated from tau_m: g = C / tau
            # (units: pF / ms -> nS)
            self.g_leak = self.Cm / self.tau_m
            self.E_exc = 0.0    # mV
            self.E_inh = -75.0  # mV
            self.E_ahp = -90.0  # mV (K+ reversal)
            # ensure synaptic conductances exist in the right units
            self.g_ampa = 0.0
            self.g_gaba = 0.0

        if has_t_current:
            self.h_T = 0.0
            self.I_burst = 0.0
            self.tau_T_act = 20.0
            self.tau_T_deact = 50.0
            self.E_Ca = 1.2

    def receive(self, I):
        self._pending_I += I * self._scale if I > 0 else I

    def step(self, t, dt=1.0, norepinephrine=0.0, serotonin=0.0):
        # Ornstein-Uhlenbeck noise (same semantics, units depend on mode)
        self.eta += dt * (-self.eta / self.tau_noise) + \
                    np.sqrt(2 * dt / self.tau_noise) * self.noise_std * np.random.normal()

        # Decay conductances / adaptation
        self.g_ahp += dt * (-self.g_ahp / self.adapt_tau)
        self.g_ampa += dt * (-self.g_ampa / self.tau_ampa)
        self.g_gaba += dt * (-self.g_gaba / self.tau_gaba)

        if self.has_t_current:
            self.I_burst += dt * (-self.I_burst / 8.0)

        # refractory handling
        if t - self.last_spike_time < self.refractory:
            self._pending_I = 0.0
            if self.record_history:
                self.v_history.append(self.v_reset)
            return 0

        effective_threshold = self.base_threshold + self.fatigue

        if not self.biophysical:
            # legacy normalized integrate-and-fire update
            I_ampa = self.g_ampa * (self.E_exc - self.v) * self._scale   # homeostasis scales AMPA
            I_gaba = self.g_gaba * (self.E_inh - self.v)
            I_burst = self.I_burst if self.has_t_current else 0.0
            effective_I = self._pending_I + I_ampa + I_gaba - self.g_ahp + self.eta + I_burst

            # neuromodulator gain modulation
            effective_I *= (1.0 + 0.05 * norepinephrine)
            if self.cell_type == "D2_MSN":
                effective_I *= (1.0 + 0.3 * serotonin)

            self.v += dt * (-self.v / self.tau_m + effective_I)
            self.v  = max(self.v, self.v_reset)
            self._pending_I = 0.0

            if self.has_t_current:
                if self.v < -0.2:
                    self.h_T += dt * (1.0 - self.h_T) / self.tau_T_act
                else:
                    self.h_T += dt * (0.0 - self.h_T) / self.tau_T_deact
                self.h_T = np.clip(self.h_T, 0.0, 1.0)
        else:
            # Biophysical conductance-based update (units: mV, pF, nS, pA)
            I_leak = self.g_leak * (self.E_leak - self.v)
            I_ampa = self.g_ampa * (self.E_exc - self.v) * self._scale
            I_gaba = self.g_gaba * (self.E_inh - self.v)
            I_ahp = self.g_ahp * (self.E_ahp - self.v)
            I_burst = self.I_burst if self.has_t_current else 0.0
            I_ext = self._pending_I
            I_noise = self.eta

            I_total = I_leak + I_ampa + I_gaba + I_ahp + I_burst + I_noise + I_ext

            # neuromodulator gain modulation
            I_total *= (1.0 + 0.05 * norepinephrine)
            if self.cell_type == "D2_MSN":
                I_total *= (1.0 + 0.3 * serotonin)

            # dv/dt = I_total / Cm  (pA / pF = mV/ms)
            self.v += dt * (I_total / self.Cm)
            self.v = max(self.v, self.v_reset)
            self._pending_I = 0.0

            if self.has_t_current:
                if self.v < -65.0:
                    self.h_T += dt * (1.0 - self.h_T) / self.tau_T_act
                else:
                    self.h_T += dt * (0.0 - self.h_T) / self.tau_T_deact
                self.h_T = np.clip(self.h_T, 0.0, 1.0)

        # Spike detection (shared behavior)
        if self.v >= effective_threshold:
            if self.record_history:
                self.v_history.append(effective_threshold)
            self.last_spike_time = t
            self.v = self.v_reset
            self.spike_times.append(t)
            # adaptation increment: treated as conductance in biophysical mode
            self.g_ahp += self.adapt_gain
            self.fatigue = min(self.fatigue + self.spike_cost, self.max_fatigue)
            self._spike_counter += 1
            if self.has_t_current and self.h_T > 0.4:
                self.I_burst += 0.12
            return 1

        if self.record_history:
            self.v_history.append(self.v)
        return 0

    def homeostatic_step(self, window_ms=100):
        if window_ms <= 0:
            return
        recent_rate = self._spike_counter / (window_ms * 0.001)
        self._rate_estimate = 0.9 * self._rate_estimate + 0.1 * recent_rate
        error = self.target_rate - self._rate_estimate
        self._scale += self._homeo_eta * error * 0.02
        self._scale = np.clip(self._scale, 0.2, 5.0)
        self._spike_counter = 0

    @property
    def firing_rate(self):
        return len(self.spike_times)

    def __repr__(self):
        return f"N{self.id:02d}"

# ======================================================================
#  Synapse – V16: same as V15 (ACh+DA modulated STDP)
# ======================================================================
class Synapse:
    def __init__(self, pre, post, weight=None, synapse_type="excitatory",
                 delay=1, learn_rate=0.01,
                 tau_ltp=17.0, tau_ltd=34.0, ltd_factor=0.65,
                 U=0.5, tau_facil=50.0, tau_rec=200.0,
                 use_stp=True, dopamine_receptor=None):
        self.pre          = pre
        self.post         = post
        self.weight       = weight if weight is not None else np.random.uniform(0.3, 0.6)
        self.sign         = 1.0 if synapse_type == "excitatory" else -1.0
        self.synapse_type = synapse_type
        self.delay        = delay
        self.learn_rate   = learn_rate
        self.tau_ltp      = tau_ltp
        self.tau_ltd      = tau_ltd
        self.ltd_factor   = ltd_factor
        self._buffer      = deque([(0.0, None)] * delay, maxlen=delay)
        self.use_stp      = use_stp
        self.U            = U
        self.tau_facil    = tau_facil
        self.tau_rec      = tau_rec
        # Tsodyks–Markram variables
        self.u = U
        self.R = 1.0
        self.last_pre_spike = -1000
        self.dopamine_receptor = dopamine_receptor

    def deliver(self):
        g_inc, syn_type = self._buffer.popleft()
        if g_inc != 0.0 and syn_type is not None:
            if syn_type == "excitatory":
                self.post.g_ampa += g_inc
            else:
                self.post.g_gaba += g_inc

    def enqueue(self, pre_fired):
        if pre_fired:
            if not self.use_stp or self.synapse_type == "inhibitory":
                g_inc = self.weight
            else:
                # Tsodyks–Markram update on presynaptic spike
                # facilitation
                self.u = self.u + self.U * (1.0 - self.u)
                # effective released fraction
                release = self.u * self.R
                # consume resources
                self.R = max(0.0, self.R - release)
                g_inc = self.weight * release
                self.last_pre_spike = 0
            self._buffer.append((g_inc, self.synapse_type))
        else:
            # append empty event to maintain delay buffer length
            self._buffer.append((0.0, None))

    def step(self, dt=1.0):
        if not self.use_stp:
            return
        # Recovery dynamics for Tsodyks–Markram
        # R recovers to 1.0, u decays toward baseline U
        self.R += dt * ((1.0 - self.R) / self.tau_rec)
        self.u += dt * (-(self.u - self.U) / self.tau_facil)
        # clamp
        if self.R > 1.0:
            self.R = 1.0
        if self.u < 0.0:
            self.u = 0.0
        if self.u > 1.0:
            self.u = 1.0

    def stdp_update(self, t_post, dopamine=0.0, acetylcholine=0.0):
        delta_t = t_post - self.pre.last_spike_time
        if delta_t > 0:
            dw = self.learn_rate * np.exp(-delta_t / self.tau_ltp)
        else:
            dw = -self.learn_rate * self.ltd_factor * np.exp(delta_t / self.tau_ltd)
        dw *= (1.0 + acetylcholine)
        if self.dopamine_receptor == 'D1':
            if dw > 0:
                dw *= (1.0 + dopamine)
            else:
                dw *= (1.0 - 0.5 * dopamine)
        elif self.dopamine_receptor == 'D2':
            if dw > 0:
                dw *= (1.0 - dopamine)
            else:
                dw *= (1.0 + dopamine)
        self.weight = np.clip(self.weight + dw, 0.0, 2.0)

# ======================================================================
#  BrainRegion – V16 (interneuron targets scale with target_rate_i)
# ======================================================================
class BrainRegion:
    def __init__(self, name, n_excitatory, n_inhibitory, p_connect=0.30,
                 recurrent=False, tau_m=20.0, threshold=0.55,
                 noise_std=0.008, refractory=5,
                 target_rate=15.0, target_rate_i=20.0,
                 interneuron_types=None, biophysical=False):
        self.name              = name
        self.internal_synapses = []
        self.interneuron_types = interneuron_types

        self.excitatory = []
        for i in range(n_excitatory):
            if i < n_excitatory // 3:
                layer = 4
            elif i < 2 * n_excitatory // 3:
                layer = 23
            else:
                layer = 56
            self.excitatory.append(
                BrainNeuron(tau_m=tau_m, threshold=threshold,
                            noise_std=noise_std, refractory=refractory,
                            target_rate=target_rate,
                            adapt_gain=0.012, adapt_tau=200.0,
                            layer=layer, cell_type="excitatory",
                            biophysical=biophysical))

        self.inhibitory = []
        for i in range(n_inhibitory):
            if interneuron_types and i < len(interneuron_types):
                int_type = interneuron_types[i]
            else:
                int_type = "generic"

            if int_type == "PV":
                tau_i = tau_m * 0.5
                th_i  = threshold * 0.6
                ag    = 0.003
                at    = 80.0
                ref   = max(1, refractory - 3)
                tr    = target_rate_i * 1.25
            elif int_type == "SST":
                tau_i = tau_m * 0.70
                th_i  = threshold * 0.85
                ag    = 0.015
                at    = 200.0
                ref   = max(2, refractory - 1)
                tr    = target_rate_i * 0.9
            elif int_type == "VIP":
                tau_i = tau_m * 0.65
                th_i  = threshold * 0.80
                ag    = 0.010
                at    = 150.0
                ref   = max(2, refractory - 2)
                tr    = target_rate_i * 0.6
            else:
                tau_i = tau_m * 0.65
                th_i  = threshold * 0.80
                ag    = 0.008
                at    = 150.0
                ref   = max(2, refractory - 2)
                tr    = target_rate_i

            self.inhibitory.append(
                BrainNeuron(tau_m=tau_i, threshold=th_i,
                            noise_std=noise_std, refractory=ref,
                            target_rate=tr,
                            adapt_gain=ag, adapt_tau=at,
                            layer=0, cell_type=int_type,
                            biophysical=biophysical))

        self.neurons = self.excitatory + self.inhibitory

        n_in = max(1, n_excitatory // 3)
        n_out = max(1, n_excitatory // 3)
        self.input_neurons  = self.excitatory[:n_in]
        self.output_neurons = self.excitatory[-n_out:]

        self._wire(p_connect, recurrent)

    def _wire(self, p, recurrent):
        boost_E_E = {
            (4, 23): 2.0, (23, 56): 1.8, (23, 23): 1.2,
            (56, 56): 1.2, (4, 56): 0.6, (56, 23): 0.5, (4, 4): 0.5,
        }

        for pre in self.neurons:
            is_exc_pre = pre in self.excitatory
            pre_layer = getattr(pre, 'layer', 0)
            pre_int = getattr(pre, 'cell_type', '') if not is_exc_pre else ''

            for post in self.neurons:
                if pre is post:
                    continue
                is_exc_post = post in self.excitatory
                post_layer = getattr(post, 'layer', 0)
                post_int = getattr(post, 'cell_type', '') if not is_exc_post else ''

                if   is_exc_pre and is_exc_post:   prob = p * 0.80
                elif is_exc_pre and not is_exc_post: prob = p * 2.0
                elif not is_exc_pre and is_exc_post: prob = p * 1.50
                else:                                prob = p * 0.15

                if is_exc_pre and is_exc_post:
                    key = (pre_layer, post_layer)
                    if key in boost_E_E:
                        prob *= boost_E_E[key]

                if not is_exc_pre and is_exc_post:
                    if pre_int == "PV":
                        prob = p * 2.0
                    elif pre_int == "SST":
                        prob = p * 1.2
                    elif pre_int == "VIP":
                        prob = p * 0.4
                elif not is_exc_pre and not is_exc_post:
                    if pre_int == "PV":
                        prob = p * 0.2
                    elif pre_int == "SST":
                        if post_int == "VIP":
                            prob = p * 2.0
                        else:
                            prob = p * 0.3
                    elif pre_int == "VIP":
                        if post_int == "SST":
                            prob = p * 1.8
                        else:
                            prob = p * 0.2

                if recurrent and is_exc_pre and is_exc_post:
                    prob = min(prob * 1.5, 0.90)

                if np.random.random() < prob:
                    syn_type = "excitatory" if is_exc_pre else "inhibitory"
                    if syn_type == "excitatory":
                        w = np.random.uniform(0.50, 0.70)
                    elif is_exc_post:
                        w = np.random.uniform(0.60, 0.90)
                    else:
                        w = np.random.uniform(0.10, 0.25)
                    delay = gamma_delay((1, 4))
                    self.internal_synapses.append(
                        Synapse(pre, post, weight=w,
                                synapse_type=syn_type, delay=delay,
                                use_stp=(syn_type == "excitatory")))

        if len(self.excitatory) > 1 and len(self.input_neurons) > 0:
            for post in self.excitatory:
                if post in self.input_neurons:
                    continue
                if not any(s.pre in self.input_neurons and s.post is post
                           and s.synapse_type == "excitatory"
                           for s in self.internal_synapses):
                    candidates = list(self.input_neurons)
                    np.random.shuffle(candidates)
                    for inp in candidates[:2]:
                        delay = gamma_delay((1, 4))
                        self.internal_synapses.append(
                            Synapse(inp, post,
                                    weight=np.random.uniform(0.55, 0.75),
                                    synapse_type="excitatory", delay=delay,
                                    use_stp=False))

    def stimulate(self, I, target="input"):
        pool = self.input_neurons if target == "input" else self.excitatory
        for n in pool:
            n.receive(I)

    def project_to(self, other, n_connections, weight_range,
                   delay_range, learn_rate, target="input",
                   dopamine_receptor=None):
        post_pool = (other.input_neurons if target == "input"
                     else other.inhibitory)
        synapses = []
        for _ in range(n_connections):
            pre   = np.random.choice(self.output_neurons)
            post  = np.random.choice(post_pool)
            w     = np.random.uniform(*weight_range)
            delay = gamma_delay(delay_range)
            synapses.append(Synapse(pre, post, weight=w,
                                    synapse_type="excitatory",
                                    delay=delay, learn_rate=learn_rate,
                                    use_stp=False,
                                    dopamine_receptor=dopamine_receptor))
        return synapses

    def stats(self):
        e_sp = sum(n.firing_rate for n in self.excitatory)
        i_sp = sum(n.firing_rate for n in self.inhibitory)
        avg_fatigue = np.mean([n.fatigue for n in self.neurons])
        print(f"\n  [{self.name}]  {len(self.excitatory)}E + {len(self.inhibitory)}I"
              f"  |  {len(self.internal_synapses)} internal synapses"
              f"  |  avg fatigue = {avg_fatigue:.3f}")
        print(f"  E spikes: {e_sp}   I spikes: {i_sp}")
        for n in self.neurons:
            kind = "E" if n in self.excitatory else "I"
            int_str = f" {n.cell_type}" if kind == "I" else ""
            layer_str = f"L{getattr(n, 'layer', '')} " if kind == "E" else "    "
            tag  = (" ←in " if n in self.input_neurons else
                    " →out" if n in self.output_neurons else "     ")
            bar  = "█" * min(n.firing_rate, 40)
            print(f"    {n}[{kind}{int_str}] {layer_str}{tag}  {n.firing_rate:3d}  |{bar}")

# ======================================================================
#  Thalamus – V16 (unchanged from V15)
# ======================================================================
class Thalamus(BrainRegion):
    def __init__(self, name="Thalamus", n_relay=4, n_trn=2,
                 p_connect=0.20, noise_std=0.010, target_rate_i=25.0,
                 biophysical=False):
        self.name              = name
        self.internal_synapses = []

        self.excitatory = [BrainNeuron(tau_m=15.0, threshold=0.50,
                           noise_std=noise_std, refractory=3,
                           target_rate=15.0,
                           adapt_gain=0.003, adapt_tau=250.0,
                           layer=0, cell_type="excitatory",
                           has_t_current=True, biophysical=biophysical)
                   for _ in range(n_relay)]
        self.inhibitory = [BrainNeuron(tau_m=8.0, threshold=0.38,
                           noise_std=noise_std, refractory=2,
                           target_rate=target_rate_i,
                           adapt_gain=0.008, adapt_tau=120.0,
                           layer=0, cell_type="TRN", biophysical=biophysical)
                   for _ in range(n_trn)]
        self.neurons = self.excitatory + self.inhibitory
        self.input_neurons  = self.excitatory
        self.output_neurons = self.excitatory

        self._wire_thalamus(p_connect)

    def _wire_thalamus(self, p):
        for pre in self.neurons:
            is_tc = pre in self.excitatory
            for post in self.neurons:
                if pre is post:
                    continue
                is_tc_post = post in self.excitatory

                if   is_tc and not is_tc_post:    prob = p * 0.60   # V15: reduced TC→TRN
                elif not is_tc and is_tc_post:    prob = p * 1.60
                elif not is_tc and not is_tc_post: prob = p * 0.10
                else:                              prob = 0.0

                if prob > 0 and np.random.random() < prob:
                    syn_type = "excitatory" if is_tc else "inhibitory"
                    if syn_type == "excitatory":
                        w = np.random.uniform(0.40, 0.55)
                    else:
                        w = np.random.uniform(0.50, 0.80)
                    delay = gamma_delay((1, 3))
                    self.internal_synapses.append(
                        Synapse(pre, post, weight=w,
                                synapse_type=syn_type, delay=delay,
                                use_stp=False))

    def receive_input(self, I):
        for n in self.excitatory:
            n.receive(I)

# ======================================================================
#  BASAL GANGLIA REGIONS (same as V15)
# ======================================================================

class StriatumD1(BrainRegion):
    def __init__(self, name="Striatum D1", n_neurons=8, p_connect=0.20,
                 noise_std=0.010, biophysical=False):
        self.name              = name
        self.internal_synapses = []
        self.excitatory = []
        self.inhibitory = [BrainNeuron(tau_m=18.0, threshold=0.50,
                           noise_std=noise_std, refractory=4,
                           target_rate=10.0,
                           adapt_gain=0.015, adapt_tau=180.0,
                           layer=0, cell_type="D1_MSN", biophysical=biophysical)
                   for _ in range(n_neurons)]
        self.neurons = self.inhibitory
        self.input_neurons  = self.inhibitory
        self.output_neurons = self.inhibitory
        self._wire_striatum(p_connect)

    def _wire_striatum(self, p):
        for pre in self.neurons:
            for post in self.neurons:
                if pre is post:
                    continue
                if np.random.random() < p * 0.10:
                    w = np.random.uniform(0.05, 0.15)
                    delay = gamma_delay((1, 3))
                    self.internal_synapses.append(
                        Synapse(pre, post, weight=w,
                                synapse_type="inhibitory", delay=delay,
                                use_stp=False))

