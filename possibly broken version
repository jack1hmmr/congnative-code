def wire_sparse_region(region, fanout=8):
    """Create a sparse internal wiring for `region` where each presynaptic
    neuron connects to `fanout` random postsynaptic targets (no O(N^2) loops).
    """
    neurons = region.neurons
    N = len(neurons)
    if N <= 1:
        return
    for pre in neurons:
        is_exc_pre = pre in region.excitatory
        k = min(max(1, int(fanout)), N - 1)
        posts_pool = [n for n in neurons if n is not pre]
        if len(posts_pool) == 0:
            continue
        k = min(k, len(posts_pool))
        chosen = list(np.random.choice(posts_pool, size=k, replace=False))
        for post in chosen:
            syn_type = "excitatory" if is_exc_pre else "inhibitory"
            if syn_type == "excitatory":
                w = np.random.uniform(0.50, 0.70)
                use_stp = True
            else:
                w = np.random.uniform(0.10, 0.25)
                use_stp = False
            delay = gamma_delay((1, 4))
            s = Synapse(pre, post, weight=w, synapse_type=syn_type, delay=delay, use_stp=use_stp)
            region.internal_synapses.append(s)


def build_scaled_brain(scale=1, fanout=8, biophysical=False, outgoing_fanout=2):
    """Construct a Brain with region sizes multiplied by `scale`.
    Regions are created with `p_connect=0.0` to avoid expensive O(N^2)
    wiring in constructors; internal synapses are then created with
    `wire_sparse_region` (O(N * fanout)).
    """
    brain = Brain()

    # scaled region sizes (base -> scaled)
    thalamus = Thalamus(name="Thalamus",
                        n_relay=max(1, int(8 * scale)),
                        n_trn=max(1, int(4 * scale)),
                        p_connect=0.0, biophysical=biophysical)
    brain.add_region(thalamus)
    wire_sparse_region(thalamus, fanout=fanout)

    cortex = BrainRegion(name="Cortex",
                         n_excitatory=max(1, int(18 * scale)),
                         n_inhibitory=max(1, int(4 * scale)),
                         p_connect=0.0, recurrent=False,
                         interneuron_types=["PV", "PV", "SST", "VIP"],
                         biophysical=biophysical)
    brain.add_region(cortex)
    wire_sparse_region(cortex, fanout=fanout)

    hippocampus = BrainRegion(name="Hippocampus",
                              n_excitatory=max(1, int(15 * scale)),
                              n_inhibitory=max(1, int(3 * scale)),
                              p_connect=0.0, recurrent=True,
                              interneuron_types=["PV", "SST", "VIP"],
                              biophysical=biophysical)
    brain.add_region(hippocampus)
    wire_sparse_region(hippocampus, fanout=fanout)

    striatum_d1 = StriatumD1(name="Striatum D1", n_neurons=max(1, int(8 * scale)), p_connect=0.0, biophysical=biophysical)
    brain.add_region(striatum_d1)
    wire_sparse_region(striatum_d1, fanout=max(1, int(fanout//2)))

    striatum_d2 = StriatumD2(name="Striatum D2", n_neurons=max(1, int(8 * scale)), p_connect=0.0, biophysical=biophysical)
    brain.add_region(striatum_d2)
    wire_sparse_region(striatum_d2, fanout=max(1, int(fanout//2)))

    gpe = GPe(name="GPe", n_neurons=max(1, int(4 * scale)), p_connect=0.0, biophysical=biophysical)
    brain.add_region(gpe)
    wire_sparse_region(gpe, fanout=max(1, int(fanout//2)))

    gpi = GPi(name="GPi", n_neurons=max(1, int(4 * scale)), p_connect=0.0, biophysical=biophysical)
    brain.add_region(gpi)
    wire_sparse_region(gpi, fanout=max(1, int(fanout//2)))

    stn = STN(name="STN", n_neurons=max(1, int(4 * scale)), p_connect=0.0, biophysical=biophysical)
    brain.add_region(stn)
    wire_sparse_region(stn, fanout=max(1, int(fanout//2)))

    # Inter-region projections: scale base connection counts but cap by output size * fanout
    def safe_connect(pre, post, base_n, ptype="feedforward", target="input", dopamine_receptor=None):
        max_conn = max(1, int(len(pre.output_neurons) * outgoing_fanout))
        n_conn = min(max_conn, max(1, int(base_n * scale)))
        brain.connect(pre, post, projection_type=ptype, n_connections=n_conn, target=target, dopamine_receptor=dopamine_receptor)

    safe_connect(thalamus, cortex, 36, ptype="feedforward")
    safe_connect(cortex, thalamus, 8, ptype="feedback", target="inhibitory")
    safe_connect(cortex, hippocampus, 30, ptype="feedforward")
    safe_connect(hippocampus, cortex, 18, ptype="feedback")
    safe_connect(cortex, striatum_d1, 24, ptype="feedforward", dopamine_receptor='D1')
    safe_connect(cortex, striatum_d2, 24, ptype="feedforward", dopamine_receptor='D2')
    safe_connect(cortex, stn, 12, ptype="feedforward")
    safe_connect(striatum_d1, gpi, 16, ptype="feedforward", target="input")
    safe_connect(striatum_d2, gpe, 12, ptype="feedforward", target="input")
    safe_connect(gpe, stn, 8, ptype="feedforward", target="input")
    safe_connect(stn, gpe, 8, ptype="feedforward", target="input")
    safe_connect(gpe, gpi, 8, ptype="feedforward", target="input")
    safe_connect(stn, gpi, 12, ptype="feedforward", target="input")
    safe_connect(gpi, thalamus, 12, ptype="feedback", target="inhibitory")

    # Ensure any internal synapses created after regions were added are registered
    for region in brain.regions:
        for s in getattr(region, "internal_synapses", []):
            if s not in brain._all_synapses:
                brain._all_synapses.append(s)

    return brain


def validate_connectivity(brain, verbose=True):
    """Basic connectivity validator and summary for a built `brain`.
    Prints total neurons/synapses, excitatory/inhibitory split, in/out degree
    statistics and a region->region connection matrix. Returns a dict of
    summary arrays for programmatic checks.
    """
    import numpy as _np

    neurons = list(brain._all_neurons)
    N = len(neurons)
    syns = list(brain._all_synapses)
    S = len(syns)
    if verbose:
        print(f"Connectivity: {N} neurons, {S} synapses, {len(brain.regions)} regions")
    if N == 0:
        return {}

    # duplicate-check
    ids = [id(s) for s in syns]
    if len(set(ids)) != len(ids) and verbose:
        print("  WARNING: duplicate Synapse objects in brain._all_synapses")

    # per-neuron degrees
    idx = {n: i for i, n in enumerate(neurons)}
    in_deg = _np.zeros(N, dtype=int)
    out_deg = _np.zeros(N, dtype=int)
    exc = inh = 0
    for s in syns:
        out_deg[idx[s.pre]] += 1
        in_deg[idx[s.post]] += 1
        if s.synapse_type == 'excitatory':
            exc += 1
        else:
            inh += 1

    exc_pct = (exc / S * 100.0) if S > 0 else 0.0
    inh_pct = (inh / S * 100.0) if S > 0 else 0.0
    if verbose:
        print(f"  Excitatory: {exc} ({exc_pct:.1f}%), Inhibitory: {inh} ({inh_pct:.1f}%)")
        print(f"  In-degree per neuron: min={int(in_deg.min())}, median={int(_np.median(in_deg))}, mean={in_deg.mean():.2f}, max={int(in_deg.max())}")
        print(f"  Out-degree per neuron: min={int(out_deg.min())}, median={int(_np.median(out_deg))}, mean={out_deg.mean():.2f}, max={int(out_deg.max())}")

    # region->region matrix
    region_list = brain.regions
    R = len(region_list)
    region_index = {r.name: i for i, r in enumerate(region_list)}
    region_of = {}
    for r in region_list:
        for n in r.neurons:
            region_of[n] = r.name

    mat = _np.zeros((R, R), dtype=int)
    for s in syns:
        pre_reg = region_of.get(s.pre)
        post_reg = region_of.get(s.post)
        if pre_reg is None or post_reg is None:
            continue
        mat[region_index[pre_reg], region_index[post_reg]] += 1

    if verbose:
        names = [r.name for r in region_list]
        print("  Region->Region matrix:")
        print("    " + " ".join(f"{n[:10]:>10s}" for n in names))
        for i, row in enumerate(mat):
            print(f"    {names[i][:10]:>10s} " + " ".join(f"{c:10d}" for c in row))

    # connected components (undirected)
    adj = {n: set() for n in neurons}
    for s in syns:
        adj[s.pre].add(s.post); adj[s.post].add(s.pre)
    visited = set(); components = []
    for n in neurons:
        if n in visited: continue
        stack = [n]; comp = set()
        while stack:
            cur = stack.pop()
            if cur in visited: continue
            visited.add(cur); comp.add(cur)
            for nb in adj[cur]:
                if nb not in visited:
                    stack.append(nb)
        components.append(comp)
    comp_sizes = sorted([len(c) for c in components], reverse=True)
    largest_pct = (comp_sizes[0] / N * 100.0) if N > 0 and comp_sizes else 0.0
    if verbose:
        print(f"  Connected components: {len(components)}; largest={comp_sizes[0] if comp_sizes else 0} ({largest_pct:.1f}%)")
        if len(components) > 1:
            print("  Component sizes (top 5):", comp_sizes[:5])

    return dict(N=N, S=S, regions=[r.name for r in region_list], in_deg=in_deg, out_deg=out_deg, matrix=mat, component_sizes=comp_sizes)


def dedupe_synapses(brain, verbose=True):
    """Remove duplicate synapses from `brain._all_synapses`, region.internal_synapses,
    and projection lists. Duplicates are detected by (pre.id, post.id, syn_type, weight, delay).
    Returns number of removed synapses.
    """
    removed = 0
    seen = set()
    new_all = []
    for s in list(brain._all_synapses):
        key = (getattr(s.pre, 'id', id(s.pre)), getattr(s.post, 'id', id(s.post)),
               s.synapse_type, round(float(s.weight), 6), int(s.delay))
        if key in seen:
            removed += 1
            continue
        seen.add(key)
        new_all.append(s)

    if removed > 0:
        brain._all_synapses.clear()
        brain._all_synapses.extend(new_all)

    # Deduplicate region.internal_synapses lists
    for region in brain.regions:
        new_internal = []
        seen_local = set()
        for s in getattr(region, 'internal_synapses', []):
            key = (getattr(s.pre, 'id', id(s.pre)), getattr(s.post, 'id', id(s.post)),
                   s.synapse_type, round(float(s.weight), 6), int(s.delay))
            if key in seen_local:
                continue
            seen_local.add(key)
            new_internal.append(s)
        region.internal_synapses = new_internal

    # Deduplicate projection_map syn lists
    new_proj = []
    for pre, post, ptype, syns in list(brain._projection_map):
        uniq = []
        seen_local = set()
        for s in syns:
            key = (getattr(s.pre, 'id', id(s.pre)), getattr(s.post, 'id', id(s.post)),
                   s.synapse_type, round(float(s.weight), 6), int(s.delay))
            if key in seen_local:
                continue
            seen_local.add(key)
            uniq.append(s)
        new_proj.append((pre, post, ptype, uniq))
    brain._projection_map = new_proj

    if verbose:
        print(f"dedupe_synapses: removed {removed} duplicate synapses")
    return removed


