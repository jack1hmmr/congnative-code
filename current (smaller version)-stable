    "class GPe(BrainRegion):\n",
    "    def __init__(self, name=\"GPe\", n_neurons=4, p_connect=0.25, noise_std=0.010):\n",
    "        self.name              = name\n",
    "        self.internal_synapses = []\n",
    "        self.excitatory = []\n",
    "        self.inhibitory = [BrainNeuron(tau_m=10.0, threshold=0.30,\n",
    "                                       noise_std=noise_std, refractory=2,\n",
    "                                       target_rate=30.0,\n",
    "                                       adapt_gain=0.005, adapt_tau=100.0,\n",
    "                                       layer=0, cell_type=\"GPe\")\n",
    "                           for _ in range(n_neurons)]\n",
    "        self.neurons = self.inhibitory\n",
    "        self.input_neurons  = self.inhibitory\n",
    "        self.output_neurons = self.inhibitory\n",
    "        self._wire_gpe(p_connect)\n",
    "\n",
    "    def _wire_gpe(self, p):\n",
    "        for pre in self.neurons:\n",
    "            for post in self.neurons:\n",
    "                if pre is post:\n",
    "                    continue\n",
    "                if np.random.random() < p * 0.30:\n",
    "                    w = np.random.uniform(0.20, 0.40)\n",
    "                    delay = gamma_delay((1, 3))\n",
    "                    self.internal_synapses.append(\n",
    "                        Synapse(pre, post, weight=w,\n",
    "                                synapse_type=\"inhibitory\", delay=delay,\n",
    "                                use_stp=False))\n",
    "\n",
    "    def project_to(self, other, n_connections, weight_range,\n",
    "                   delay_range, learn_rate, target=\"input\",\n",
    "                   dopamine_receptor=None):\n",
    "        post_pool = (other.input_neurons if target == \"input\"\n",
    "                     else other.inhibitory)\n",
    "        synapses = []\n",
    "        for _ in range(n_connections):\n",
    "            pre   = np.random.choice(self.output_neurons)\n",
    "            post  = np.random.choice(post_pool)\n",
    "            w     = np.random.uniform(*weight_range)\n",
    "            delay = gamma_delay(delay_range)\n",
    "            synapses.append(Synapse(pre, post, weight=w,\n",
    "                                    synapse_type=\"inhibitory\",\n",
    "                                    delay=delay, learn_rate=learn_rate,\n",
    "                                    use_stp=False,\n",
    "                                    dopamine_receptor=dopamine_receptor))\n",
    "        return synapses\n",
    "\n",
    "    def stats(self):\n",
    "        i_sp = sum(n.firing_rate for n in self.inhibitory)\n",
    "        avg_fatigue = np.mean([n.fatigue for n in self.neurons])\n",
    "        print(f\"\\n  [{self.name}]  {len(self.inhibitory)} cells (GABA)\"\n",
    "              f\"  |  {len(self.internal_synapses)} internal synapses\"\n",
    "              f\"  |  avg fatigue = {avg_fatigue:.3f}\")\n",
    "        print(f\"  I spikes: {i_sp}\")\n",
    "        for n in self.neurons:\n",
    "            bar  = \"█\" * min(n.firing_rate, 40)\n",
    "            print(f\"    {n}[I {n.cell_type}]        {n.firing_rate:3d}  |{bar}\")\n",
    "\n",
